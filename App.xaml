<Application x:Class="MonolithVpnClient.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MonolithVpnClient"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Theme.xaml"/>
                <ResourceDictionary Source="Themes/Icons.xaml"/>
                <ResourceDictionary Source="Themes/Effects.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <local:StringToVisibilityConverter x:Key="StringToVis"/>
            <local:InverseBoolConverter x:Key="InverseBool"/>
            <local:InverseStringToVisibilityConverter x:Key="InverseStringToVis"/>
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <local:AlertKindToBrushConverter x:Key="AlertKindToBrush"/>
            <local:HistoryActionToBrushConverter x:Key="HistoryActionToBrush"/>
            <local:TagColorToBrushConverter x:Key="TagColorToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
