<UserControl x:Class="MonolithVpnClient.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonolithVpnClient.Views">
    <DockPanel>
        <views:PageHeader DockPanel.Dock="Top" Margin="0,0,0,16" Title="Profile"/>

        <StackPanel VerticalAlignment="Top">
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Account" FontWeight="SemiBold" Foreground="{StaticResource TextHi}"/>
                    <TextBlock Text="Username" Foreground="{StaticResource TextLow}" FontSize="12" Margin="0,12,0,2"/>
                    <TextBlock x:Name="UsernameText" Foreground="{StaticResource TextHi}" FontSize="15"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Plan" FontWeight="SemiBold" Foreground="{StaticResource TextHi}"/>
                    <TextBlock x:Name="PlanNameText" Foreground="{StaticResource TextHi}" FontSize="15" Margin="0,12,0,0"/>
                    <TextBlock x:Name="DeviceLimitText" Foreground="{StaticResource TextMid}" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock x:Name="NoPlanText" Text="No plan on file yet." Foreground="{StaticResource TextLow}"
                               Margin="0,12,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <TextBlock Text="This app is read-only for your account. To change your username, password, or plan, use the website."
                       Foreground="{StaticResource TextLow}" FontSize="12" TextWrapping="Wrap"/>
        </StackPanel>
    </DockPanel>
</UserControl>
