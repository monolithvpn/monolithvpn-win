<Window x:Class="MonolithVpnClient.Views.ProcessPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MonolithVpnClient.Views"
        Width="460" Height="560"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border Style="{StaticResource Card}" Effect="{StaticResource ShadowPopup}" Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                <views:LogoMark Width="18" Height="18"/>
                <TextBlock Text="MonolithVPN" FontSize="11" Foreground="{StaticResource TextLow}"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>
            <TextBlock DockPanel.Dock="Top" Text="Pick a running program"
                       FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextHi}"
                       Margin="0,12,0,0"/>
            <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource TextLow}" FontSize="12"
                       Margin="0,6,0,12" TextWrapping="Wrap"
                       Text="Shows currently running programs - handy if the game or app is already open and you don't want to hunt for its .exe."/>

            <TextBox x:Name="SearchBox" DockPanel.Dock="Top" Style="{StaticResource AppTextBox}"
                     Margin="0,0,0,10" TextChanged="SearchBox_TextChanged"/>
            <TextBlock DockPanel.Dock="Top" x:Name="EmptyText" Text="No matching running programs found."
                       Foreground="{StaticResource TextLow}" FontSize="12" Visibility="Collapsed" Margin="0,0,0,10"/>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource OutlineButton}" Height="38"
                        Padding="16,0" Margin="0,0,10,0" Click="CancelButton_Click"/>
                <Button x:Name="SelectButton" Content="Select" Style="{StaticResource PrimaryButton}" Height="38"
                        Padding="16,0" IsEnabled="False" Click="SelectButton_Click"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="ProcessList" BorderThickness="0" Background="Transparent"
                         SelectionChanged="ProcessList_SelectionChanged" MouseDoubleClick="ProcessList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,6,0,6">
                                <TextBlock Text="{Binding DisplayName}" FontSize="13" Foreground="{StaticResource TextHi}"/>
                                <TextBlock Text="{Binding ExePath}" FontSize="11" Foreground="{StaticResource TextLow}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
