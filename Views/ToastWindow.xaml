<Window x:Class="MonolithVpnClient.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MonolithVpnClient.Views"
        Width="320" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Border Style="{StaticResource Card}" Effect="{StaticResource ShadowPopup}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="AccentBar" Grid.Column="0" Width="4" CornerRadius="2"
                    Background="{StaticResource Green}" Margin="0,0,12,0"/>

            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <views:LogoMark Width="16" Height="16"/>
                    <TextBlock Text="MonolithVPN" FontSize="11" Foreground="{StaticResource TextLow}"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextHi}"
                           Margin="0,6,0,0" TextWrapping="Wrap"/>
                <TextBlock x:Name="MessageText" FontSize="12.5" Foreground="{StaticResource TextMid}"
                           Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
