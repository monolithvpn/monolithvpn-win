<UserControl x:Class="MonolithVpnClient.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonolithVpnClient.Views">
    <DockPanel>
        <views:PageHeader DockPanel.Dock="Top" Margin="0,0,0,16" Title="Network"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel VerticalAlignment="Top">
            <Border x:Name="StatusPanel" Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ServerNameText" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextHi}"/>
                        <Border x:Name="AttackBadge" Style="{StaticResource StatusBadgeRed}" Margin="10,0,0,0" Visibility="Collapsed">
                            <TextBlock Text="Under attack" FontSize="11" Foreground="{StaticResource Red}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource TextMid}" Margin="0,6,0,16"/>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,32,0">
                            <TextBlock Text="Server load" FontSize="12" Foreground="{StaticResource TextLow}" Margin="0,0,0,6"/>
                            <Border Background="{StaticResource BgElevated}" CornerRadius="6" Height="10" Width="240"
                                    HorizontalAlignment="Left">
                                <Border x:Name="LoadBar" Background="{StaticResource Red}" CornerRadius="6"
                                        HorizontalAlignment="Left" Width="0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Ping" FontSize="12" Foreground="{StaticResource TextLow}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="PingText" Text="-- ms" FontSize="14" Foreground="{StaticResource TextHi}"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Margin="0,20,0,6">
                        <TextBlock Text="Live throughput (this device only)" FontSize="12" Foreground="{StaticResource TextLow}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="TrafficPauseButton" Content="Capture" Style="{StaticResource OutlineButton}"
                                Height="24" Padding="10,0" HorizontalAlignment="Right" Click="TrafficPauseButton_Click"/>
                    </Grid>
                    <Border Background="{StaticResource BgElevated}" CornerRadius="6" Height="80" Width="400"
                            HorizontalAlignment="Left" ClipToBounds="True">
                        <Canvas x:Name="TrafficCanvas"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="↓" Foreground="{StaticResource Green}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="DownloadSpeedText" Text="Not capturing" Foreground="{StaticResource TextMid}"
                                   Margin="4,0,18,0" VerticalAlignment="Center"/>
                        <TextBlock Text="↑" Foreground="{StaticResource Red}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="UploadSpeedText" Text="Not capturing" Foreground="{StaticResource TextMid}"
                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="IP &amp; leak check" FontWeight="SemiBold" Foreground="{StaticResource TextHi}"/>
                    <TextBlock Text="See the IP address you're currently showing to the internet - it should match your VPN server's location while connected, and your own ISP's location while disconnected."
                               Foreground="{StaticResource TextLow}" FontSize="12" Margin="0,6,0,12" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="CheckIpButton" Content="Check my IP" Style="{StaticResource OutlineButton}"
                                Height="34" Click="CheckIpButton_Click"/>
                        <Button x:Name="CopyIpButton" Content="Copy" Style="{StaticResource OutlineButton}"
                                Height="34" Margin="10,0,0,0" Visibility="Collapsed" Click="CopyIpButton_Click"/>
                        <Button x:Name="ClearIpButton" Content="Clear" Style="{StaticResource OutlineButton}"
                                Height="34" Margin="10,0,0,0" Visibility="Collapsed" Click="ClearIpButton_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="IpResultPanel" Visibility="Collapsed" Margin="0,14,0,0">
                        <TextBlock x:Name="IpText" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextHi}"/>
                        <TextBlock x:Name="IpLocationText" Foreground="{StaticResource TextMid}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="IpErrorText" Foreground="{StaticResource Red}" FontSize="12"
                               Margin="0,10,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="NAT type" FontWeight="SemiBold" Foreground="{StaticResource TextHi}"/>
                    <TextBlock Text="How your connection maps to the internet - matters for hosting games or other peer-to-peer traffic. Works whether or not you're connected to a VPN server."
                               Foreground="{StaticResource TextLow}" FontSize="12" Margin="0,6,0,12" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="CheckNatButton" Content="Check NAT type" Style="{StaticResource OutlineButton}"
                                Height="34" HorizontalAlignment="Left" Click="CheckNatButton_Click"/>
                        <Button x:Name="ClearNatButton" Content="Clear" Style="{StaticResource OutlineButton}"
                                Height="34" Margin="10,0,0,0" Visibility="Collapsed" Click="ClearNatButton_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="NatResultPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,14,0,0">
                        <Border x:Name="NatBadge" Style="{StaticResource StatusBadgeGray}">
                            <TextBlock x:Name="NatBadgeText" Text="Unknown" FontSize="11" Foreground="{StaticResource TextLow}"/>
                        </Border>
                        <TextBlock x:Name="NatDetailText" Foreground="{StaticResource TextMid}" FontSize="12"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="NatErrorText" Foreground="{StaticResource Red}" FontSize="12"
                               Margin="0,10,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
