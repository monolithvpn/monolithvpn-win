<UserControl x:Class="MonolithVpnClient.Views.ServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonolithVpnClient.Views">
    <DockPanel>
        <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <views:PageHeader Grid.Column="0" Title="Servers" Subtitle="Pick a server to connect to."/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button x:Name="ListViewButton" Style="{StaticResource OutlineButton}" ToolTip="List view"
                        Width="36" Height="36" Padding="0" Margin="0,0,6,0" Click="ListViewButton_Click">
                    <Viewbox Width="16" Height="16">
                        <Path Data="{StaticResource IconListView}" Stretch="Uniform" Width="24" Height="24"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                    </Viewbox>
                </Button>
                <Button x:Name="GridViewButton" Style="{StaticResource OutlineButton}" ToolTip="Grid view"
                        Width="36" Height="36" Padding="0" Click="GridViewButton_Click">
                    <Viewbox Width="16" Height="16">
                        <Path Data="{StaticResource IconGridView}" Stretch="Uniform" Width="24" Height="24"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                    </Viewbox>
                </Button>
            </StackPanel>

            <Button x:Name="RefreshButton" Style="{StaticResource OutlineButton}" ToolTip="Refresh"
                    Grid.Column="2" Width="36" Height="36" Padding="0" VerticalAlignment="Center" Click="RefreshButton_Click">
                <Viewbox Width="16" Height="16">
                    <Path x:Name="RefreshIcon" Data="{StaticResource IconRefresh}" Stretch="Uniform" Width="24" Height="24"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="RefreshIconRotation" Angle="0"/>
                        </Path.RenderTransform>
                    </Path>
                </Viewbox>
            </Button>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Search by name, location, or tag" Foreground="{StaticResource TextLow}" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="SearchBox" Style="{StaticResource AppTextBox}" TextChanged="SearchBox_TextChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                <TextBlock Text="Sort by" Foreground="{StaticResource TextLow}" FontSize="12" Margin="0,0,0,4"/>
                <ComboBox x:Name="SortCombo" Style="{StaticResource AppComboBox}" SelectionChanged="SortCombo_SelectionChanged" SelectedIndex="0">
                    <ComboBoxItem Content="Lowest ping" Tag="ping"/>
                    <ComboBoxItem Content="Name (A-Z)" Tag="name"/>
                    <ComboBoxItem Content="Lowest load" Tag="load"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,16,10">
                <CheckBox x:Name="OnlineOnlyCheck" Content="Online only" Style="{StaticResource AppCheckBox}"
                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            </StackPanel>
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,16,10">
                <CheckBox x:Name="ProtectedOnlyCheck" Content="Protected only" Style="{StaticResource AppCheckBox}"
                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            </StackPanel>
            <StackPanel x:Name="FreeOnlyPanel" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,10" Visibility="Collapsed">
                <CheckBox x:Name="FreeOnlyCheck" Content="Free servers only" Style="{StaticResource AppCheckBox}"
                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            </StackPanel>
        </Grid>

        <Border x:Name="EmptyState" DockPanel.Dock="Top" Style="{StaticResource Card}" Visibility="Collapsed">
            <TextBlock Foreground="{StaticResource TextLow}" HorizontalAlignment="Center"
                       Text="No servers are available on your current plan yet." Margin="0,12"/>
        </Border>

        <Border x:Name="NoMatchesState" DockPanel.Dock="Top" Style="{StaticResource Card}" Visibility="Collapsed">
            <TextBlock Foreground="{StaticResource TextLow}" HorizontalAlignment="Center"
                       Text="No servers match your search/filters." Margin="0,12"/>
        </Border>

        <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <ItemsControl x:Name="ServerList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12" Padding="18">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="999"
                                            VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BgElevated}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasFlag}" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <ImageBrush ImageSource="{Binding Info.FlagUrl}" Stretch="UniformToFill"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding AvatarText}" FontWeight="Bold" FontSize="14"
                                                   Foreground="{StaticResource TextMid}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding HasFlag, Converter={StaticResource InverseBoolToVis}}"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="14,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Info.Name}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextHi}" VerticalAlignment="Center"/>
                                            <Border Style="{StaticResource StatusBadgeGreen}" Margin="8,0,0,0"
                                                    Visibility="{Binding Info.IsProtected, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="Protected" FontSize="11" Foreground="{StaticResource Green}"/>
                                            </Border>
                                            <Border Style="{StaticResource StatusBadgeRed}" Margin="8,0,0,0"
                                                    Visibility="{Binding Info.UnderAttack, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="Under attack" FontSize="11" Foreground="{StaticResource Red}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DisplayLocation}" Foreground="{StaticResource TextLow}"
                                                   FontSize="12.5" Margin="0,5,0,0"/>

                                        <ItemsControl ItemsSource="{Binding Info.Tags}" Margin="0,8,0,0"
                                                      Visibility="{Binding HasTags, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding Color, Converter={StaticResource TagColorToBrush}}"
                                                            BorderBrush="{Binding Color, Converter={StaticResource TagColorToBrush}, ConverterParameter=border}"
                                                            BorderThickness="1" CornerRadius="6" Padding="8,3" Margin="0,0,6,6">
                                                        <TextBlock Text="{Binding Name}" FontSize="11"
                                                                   Foreground="{Binding Color, Converter={StaticResource TagColorToBrush}, ConverterParameter=text}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource Green}" VerticalAlignment="Center"
                                                     Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}"/>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource Red}" VerticalAlignment="Center"
                                                     Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}"/>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource TextLow}" VerticalAlignment="Center"
                                                     Visibility="{Binding IsStatusUnknown, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding StatusText}" FontSize="12.5"
                                                       Foreground="{StaticResource TextMid}" VerticalAlignment="Center"
                                                       Margin="7,0,0,0"/>
                                            <TextBlock Text="{Binding Info.LoadPct, StringFormat='  ·  {0}% load'}"
                                                       FontSize="12.5" Foreground="{StaticResource TextLow}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PingDisplay, StringFormat='  ·  {0}'}"
                                                       FontSize="12.5" Foreground="{StaticResource TextLow}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding HasMultipleIps, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="IP" FontSize="12" Foreground="{StaticResource TextLow}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox Style="{StaticResource AppComboBox}" Width="170" Height="28" FontSize="12"
                                                      ItemsSource="{Binding IpOptions}" SelectedItem="{Binding SelectedIp, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}"
                                                      ToolTip="Only applies the first time this device connects to this server - after that it keeps whichever IP it started with."/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="{Binding ButtonText}"
                                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                            Style="{StaticResource ConnectToggleButton}" VerticalAlignment="Top"
                                            Width="128" Click="ConnectButton_Click"/>
                                </Grid>

                                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Red}"
                                            FontSize="12" Margin="58,10,0,0" TextWrapping="Wrap"
                                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="ServerGridList" Visibility="Collapsed">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="GridCardRoot" Style="{StaticResource Card}" Width="150" Height="150"
                                Margin="0,0,12,12" Padding="14">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="36" Height="36" CornerRadius="999" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BgElevated}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasFlag}" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <ImageBrush ImageSource="{Binding Info.FlagUrl}" Stretch="UniformToFill"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding AvatarText}" FontWeight="Bold" FontSize="12"
                                                   Foreground="{StaticResource TextMid}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding HasFlag, Converter={StaticResource InverseBoolToVis}}"/>
                                    </Border>
                                    <TextBlock Text="{Binding Info.Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextHi}" HorizontalAlignment="Center"
                                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding DisplayLocation}" FontSize="11"
                                               Foreground="{StaticResource TextLow}" HorizontalAlignment="Center"
                                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <StackPanel x:Name="GridStatusRow" Orientation="Horizontal"
                                                HorizontalAlignment="Center" Margin="0,8,0,0">
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource Green}" VerticalAlignment="Center"
                                                 Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}"/>
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource Red}" VerticalAlignment="Center"
                                                 Visibility="{Binding IsOffline, Converter={StaticResource BoolToVis}}"/>
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource TextLow}" VerticalAlignment="Center"
                                                 Visibility="{Binding IsStatusUnknown, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding PingDisplay}" FontSize="11"
                                                   Foreground="{StaticResource TextLow}" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button x:Name="GridConnectButton" Content="{Binding ButtonText}"
                                        Style="{StaticResource ConnectToggleButton}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                        Visibility="Collapsed" VerticalAlignment="Bottom" Height="30" FontSize="12"
                                        Click="ConnectButton_Click"/>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger SourceName="GridCardRoot" Property="IsMouseOver" Value="True">
                                <Setter TargetName="GridStatusRow" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="GridConnectButton" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        </ScrollViewer>

        <Border x:Name="RefreshOverlay" Background="{StaticResource OverlayScrim}" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="32" Height="32">
                    <Path Data="{StaticResource IconRefresh}" Stretch="Uniform" Width="24" Height="24"
                          Stroke="{StaticResource TextHi}" StrokeThickness="2" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" StrokeLineJoin="Round" RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="OverlaySpinnerRotation" Angle="0"/>
                        </Path.RenderTransform>
                    </Path>
                </Viewbox>
                <TextBlock Text="Refreshing..." Foreground="{StaticResource TextMid}" Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        </Grid>
    </DockPanel>
</UserControl>
