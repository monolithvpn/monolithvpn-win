<Window x:Class="MonolithVpnClient.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MonolithVpnClient.Views"
        Style="{StaticResource BaseWindowStyle}"
        Title="MonolithVPN" Height="510" Width="380" Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource BgBase}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgPanel}" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="MonolithVPN" Foreground="{StaticResource TextMid}" FontSize="12"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <Button x:Name="CloseButton" Content="&#x2715;" Style="{StaticResource IconButton}"
                            HorizontalAlignment="Right" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" Margin="40,0">
                <views:LogoMark Width="56" Height="56" HorizontalAlignment="Center"/>
                <TextBlock Text="MonolithVPN" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextHi}"
                           HorizontalAlignment="Center" Margin="0,16,0,4"/>
                <TextBlock Text="Sign in to connect" FontSize="13" Foreground="{StaticResource TextLow}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Username" FontSize="12" Foreground="{StaticResource TextMid}" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource AppTextBox}" Margin="0,0,0,14"/>

                <TextBlock Text="Password" FontSize="12" Foreground="{StaticResource TextMid}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordInput" Style="{StaticResource AppPasswordBox}" Margin="0,0,0,14"/>

                <CheckBox x:Name="RememberMeCheckBox" Content="Remember me" Style="{StaticResource AppCheckBox}"
                          IsChecked="True" Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorText" Foreground="{StaticResource Red}" FontSize="12" TextWrapping="Wrap"
                           Visibility="Collapsed" Margin="0,0,0,8"/>

                <Button x:Name="LoginButton" Content="Log in" Style="{StaticResource PrimaryButton}"
                        Margin="0,10,0,0" Click="LoginButton_Click"/>

                <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0" FontSize="12">
                    <Hyperlink x:Name="RegisterLink" Click="RegisterLink_Click">
                        No account? Create one on the website
                    </Hyperlink>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="12">
                    <Hyperlink x:Name="RecoverLink" Click="RecoverLink_Click">
                        Forgot your password? Recover on the website
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
