<UserControl x:Class="MonolithVpnClient.Views.ChangelogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonolithVpnClient.Views">
    <DockPanel>
        <views:PageHeader DockPanel.Dock="Top" Margin="0,0,0,16" Title="Changelog"/>

        <TextBlock x:Name="EmptyText" DockPanel.Dock="Top" Foreground="{StaticResource TextLow}"
                   Text="Nothing posted yet - check back soon." Visibility="Collapsed"/>
        <TextBlock x:Name="ErrorText" DockPanel.Dock="Top" Foreground="{StaticResource Red}"
                   Text="Couldn't load the changelog - try again shortly." Visibility="Collapsed"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EntryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextHi}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CreatedAt}" FontSize="12"
                                               Foreground="{StaticResource TextLow}" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="{Binding Body}" Foreground="{StaticResource TextMid}"
                                           TextWrapping="Wrap" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
