<Window x:Class="MonolithVpnClient.Views.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MonolithVpnClient.Views"
        Width="400" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border Style="{StaticResource Card}" Effect="{StaticResource ShadowPopup}" Padding="24">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <views:LogoMark Width="18" Height="18"/>
                <TextBlock Text="MonolithVPN" FontSize="11" Foreground="{StaticResource TextLow}"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextHi}"
                       Margin="0,12,0,0" TextWrapping="Wrap"/>
            <TextBlock x:Name="MessageText" FontSize="13" Foreground="{StaticResource TextMid}"
                       Margin="0,8,0,0" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button x:Name="CancelButton" Style="{StaticResource OutlineButton}" Height="38" Padding="16,0"
                        Margin="0,0,10,0" Click="CancelButton_Click"/>
                <Button x:Name="ConfirmButton" Style="{StaticResource PrimaryButton}" Height="38" Padding="16,0"
                        Click="ConfirmButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
