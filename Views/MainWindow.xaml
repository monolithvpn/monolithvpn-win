<Window x:Class="MonolithVpnClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MonolithVpnClient.Views"
        Style="{StaticResource BaseWindowStyle}"
        Title="MonolithVPN" Height="640" Width="960" MinHeight="480" MinWidth="760" Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPanel}" MouseDown="TitleBar_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center">
                    <Button x:Name="DefaultLayoutButton" Content="Default" Style="{StaticResource OutlineButton}"
                            Height="24" Padding="10,0" Margin="0,0,4,0" Click="DefaultLayoutButton_Click"/>
                    <Button x:Name="SimpleLayoutButton" Content="Simple" Style="{StaticResource OutlineButton}"
                            Height="24" Padding="10,0" Click="SimpleLayoutButton_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton" Content="&#x2013;" Style="{StaticResource IconButton}"
                            Click="MinimizeButton_Click"/>
                    <Button x:Name="CloseButton" Content="&#x2715;" Style="{StaticResource IconButton}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="SimpleLayoutHost" Grid.Row="1" Visibility="Collapsed"/>

        <Grid x:Name="DefaultLayoutGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="0,0,1,0" Effect="{StaticResource ShadowSoft}">
                <DockPanel Margin="8">
                    <Grid DockPanel.Dock="Top" Margin="4,4,4,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <views:LogoMark Width="22" Height="22"/>
                            <TextBlock x:Name="SidebarBrandText" Text="MonolithVPN" Foreground="{StaticResource TextHi}"
                                       FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button x:Name="CollapseButton" Grid.Column="1" Content="&#x2630;"
                                Style="{StaticResource IconButton}" Click="CollapseButton_Click"/>
                    </Grid>

                    <StackPanel DockPanel.Dock="Bottom" Margin="4,0,4,8">
                        <Border Height="1" Background="{StaticResource BorderSoft}" Margin="0,0,0,8"/>
                        <StackPanel x:Name="ConnectionStatusRow" Orientation="Horizontal" Margin="8,0,8,6">
                            <Border x:Name="SidebarFlagBorder" Width="14" Height="14" CornerRadius="999"
                                    Background="{StaticResource BgElevated}" VerticalAlignment="Center"
                                    Margin="0,0,6,0" Visibility="Collapsed"/>
                            <Ellipse x:Name="ConnectionStatusDot" Width="8" Height="8" Fill="{StaticResource TextLow}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ConnectionStatusText" Text="Not connected" Foreground="{StaticResource TextLow}"
                                       FontSize="12" Margin="7,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="ConnectionPingText" Foreground="{StaticResource TextLow}" FontSize="12"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="QuickConnectButton" Style="{StaticResource OutlineButton}" Padding="12,0"
                                Margin="8,0,8,6" Click="QuickConnectButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconBolt}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="QuickConnectButtonLabel" Text="Quick Connect" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="UsernameText" Foreground="{StaticResource TextMid}" FontSize="13"
                                   Margin="8,0,8,8" TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="LogoutButton" Style="{StaticResource OutlineButton}" Padding="12,0"
                                Click="LogoutButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconLogout}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="LogoutButtonLabel" Text="Log out" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock x:Name="NavSectionVpn" Text="VPN" Style="{StaticResource NavSectionLabel}" Margin="12,0,12,6"/>
                        <RadioButton x:Name="NavServers" GroupName="Nav" Style="{StaticResource NavButton}"
                                     IsChecked="True" Checked="Nav_Checked" Tag="servers">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconServers}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavServersLabel" Text="Servers" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavNetwork" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="network">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconNetwork}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavNetworkLabel" Text="Network" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavSharing" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="sharing">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconShare}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavSharingLabel" Text="Sharing" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavGaming" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="gaming">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconGaming}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavGamingLabel" Text="Gaming" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavMultiHop" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="multihop">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconMultiHop}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavMultiHopLabel" Text="Multi-hop" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <TextBlock x:Name="NavSectionActivity" Text="ACTIVITY" Style="{StaticResource NavSectionLabel}"/>
                        <RadioButton x:Name="NavAlerts" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="alerts">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconAlerts}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavAlertsLabel" Text="Alerts" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavHistory" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="history">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconHistory}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavHistoryLabel" Text="History" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavChangelog" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="changelog">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconChangelog}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavChangelogLabel" Text="Changelog" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <TextBlock x:Name="NavSectionAccount" Text="ACCOUNT" Style="{StaticResource NavSectionLabel}"/>
                        <RadioButton x:Name="NavProfile" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="profile">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconProfile}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavProfileLabel" Text="Profile" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavHelp" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="help">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconHelp}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavHelpLabel" Text="Help" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavSettings" GroupName="Nav" Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked" Tag="settings">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource IconSettings}" Stretch="Uniform" Width="24" Height="24"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                          StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Viewbox>
                                <TextBlock x:Name="NavSettingsLabel" Text="Settings" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <ContentControl x:Name="ContentHost" Grid.Column="1" Margin="24"/>
        </Grid>
    </Grid>
</Window>
