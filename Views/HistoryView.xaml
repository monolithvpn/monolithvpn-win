<UserControl x:Class="MonolithVpnClient.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonolithVpnClient.Views">
    <DockPanel>
        <views:PageHeader DockPanel.Dock="Top" Margin="0,0,0,16" Title="History"
                           Subtitle="Your own connection history - stored only on this device, never sent to us."/>

        <TextBlock x:Name="EmptyText" DockPanel.Dock="Top" Foreground="{StaticResource TextLow}"
                   Text="No connection history yet." Visibility="Collapsed"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource AccentStripeCardShell}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{Binding Action, Converter={StaticResource HistoryActionToBrush}}"
                                        CornerRadius="4,0,0,4"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,14,14,14">
                                    <TextBlock Text="{Binding Action}" FontWeight="SemiBold"
                                               Foreground="{Binding Action, Converter={StaticResource HistoryActionToBrush}}"/>
                                    <TextBlock Text="{Binding ServerName, StringFormat=' · {0}'}" Foreground="{StaticResource TextMid}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat='{}{0:g}'}"
                                           FontSize="12" Foreground="{StaticResource TextLow}" VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
