<UserControl x:Class="MonolithVpnClient.Views.SimpleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonolithVpnClient.Views">
    <Grid>
        <Border Style="{StaticResource Card}" Width="360" Padding="28"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                    <views:LogoMark Width="24" Height="24"/>
                    <TextBlock Text="MonolithVPN" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextHi}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,22">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource TextLow}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Not connected" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextHi}" Margin="9,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Server" FontSize="12" Foreground="{StaticResource TextLow}" Margin="0,0,0,6"/>
                <ComboBox x:Name="ServerCombo" Style="{StaticResource AppComboBox}" SelectionChanged="ServerCombo_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,9,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource TextLow}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Green}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Red}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Info.Name}" Foreground="{StaticResource TextHi}" FontSize="13"/>
                                    <TextBlock Text="{Binding DisplayLocation}" Foreground="{StaticResource TextLow}" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding PingDisplay}" Foreground="{StaticResource TextLow}"
                                           FontSize="11" VerticalAlignment="Center" Margin="10,0,4,0"/>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button x:Name="ConnectButton" Content="Connect" Style="{StaticResource PrimaryButton}"
                        Height="40" Margin="0,18,0,0" Click="ConnectButton_Click"/>
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource Red}" FontSize="12" Margin="0,10,0,0"
                           TextWrapping="Wrap" Visibility="Collapsed"/>
                <TextBlock x:Name="EmptyText" Foreground="{StaticResource TextLow}" FontSize="12" Margin="0,10,0,0"
                           TextWrapping="Wrap" Visibility="Collapsed" Text="No servers available right now."/>

                <StackPanel x:Name="ServerInfoPanel" Margin="0,22,0,0" Visibility="Collapsed">
                    <Border Height="1" Background="{StaticResource BorderSoft}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,36,0">
                            <TextBlock Text="Load" FontSize="12" Foreground="{StaticResource TextLow}" Margin="0,0,0,6"/>
                            <Border Background="{StaticResource BgElevated}" CornerRadius="6" Height="8" Width="120"
                                    HorizontalAlignment="Left">
                                <Border x:Name="LoadBar" Background="{StaticResource Red}" CornerRadius="6"
                                        HorizontalAlignment="Left" Width="0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Ping" FontSize="12" Foreground="{StaticResource TextLow}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="PingText" Text="-- ms" FontSize="14" Foreground="{StaticResource TextHi}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
