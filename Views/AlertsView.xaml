<UserControl x:Class="MonolithVpnClient.Views.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MonolithVpnClient.Views">
    <DockPanel>
        <views:PageHeader DockPanel.Dock="Top" Margin="0,0,0,16" Title="Alerts"/>

        <TextBlock x:Name="EmptyText" DockPanel.Dock="Top" Foreground="{StaticResource TextLow}"
                   Text="No alerts yet. We'll let you know here if a server you're connected to goes offline or looks like it's under attack."
                   TextWrapping="Wrap" Visibility="Visible"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="AlertList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource AccentStripeCardShell}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{Binding Kind, Converter={StaticResource AlertKindToBrush}}"
                                        CornerRadius="4,0,0,4"/>
                                <StackPanel Grid.Column="1" Margin="14,12,14,12">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                               Foreground="{Binding Kind, Converter={StaticResource AlertKindToBrush}}"/>
                                    <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextHi}"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:g}'}" FontSize="11"
                                               Foreground="{StaticResource TextLow}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
